{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "cycle119.qchal_sampler_map_receipt.v1",
  "title": "Cycle119 fail-closed q_chal sampler-map receipt",
  "type": "object",
  "required": [
    "authority_root",
    "source_definition_hash",
    "challenge_space",
    "challenge_distribution",
    "q_chal",
    "line_field",
    "challenge_to_line_parameter_map",
    "bad_event_pullback_or_filter",
    "duplicate_policy",
    "quotient_or_charge_policy",
    "final_retained_numerator"
  ],
  "properties": {
    "authority_root": {
      "description": "Payload hash; valid only when independently supplied as the checker trust pin.",
      "type": ["string", "null"],
      "pattern": "^[0-9a-f]{64}$"
    },
    "source_definition_hash": {
      "const": "89ebe887c02064a52b840c5e96992ff4f328575280a8f6dbed86e2b7dd7e7327"
    },
    "challenge_space": {"$ref": "#/$defs/fieldOrUndefined"},
    "challenge_distribution": {"$ref": "#/$defs/distributionOrUndefined"},
    "q_chal": {"type": ["integer", "null"], "minimum": 2},
    "line_field": {"$ref": "#/$defs/fieldOrUndefined"},
    "challenge_to_line_parameter_map": {"$ref": "#/$defs/mapOrUndefined"},
    "bad_event_pullback_or_filter": {"$ref": "#/$defs/eventOrUndefined"},
    "duplicate_policy": {"$ref": "#/$defs/duplicateOrUndefined"},
    "quotient_or_charge_policy": {"$ref": "#/$defs/chargeOrUndefined"},
    "final_retained_numerator": {"$ref": "#/$defs/finalOrUndefined"}
